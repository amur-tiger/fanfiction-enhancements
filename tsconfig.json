{
	"compilerOptions": {
		"moduleResolution": "node",
		"target": "es2017",
		"sourceMap": true,
		"lib": [
			"dom",
			"es2017"
		],
		"typeRoots": [
			"node_modules/@types",
			"typings"
		],
		"jsx": "react",
		"strictNullChecks": true,
		"strictBindCallApply": true,
		"strictFunctionTypes": true,
		"strictPropertyInitialization": true
	},
	"exclude": [
		"node_modules",
		"gulpfile.ts"
	]
}
